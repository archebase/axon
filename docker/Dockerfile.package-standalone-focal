# =============================================================================
# Axon Standalone Package Build - Ubuntu 20.04 (Focal)
# =============================================================================
# Build environment for creating Axon packages for Ubuntu 20.04.
# These packages are suitable for installation on Ubuntu 20.04 systems.
# =============================================================================

FROM ubuntu:20.04

# Prevent interactive prompts during package installation
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

ARG AXON_APT_MIRROR=default
COPY docker/scripts/setup-apt-mirror.sh docker/scripts/install-nodejs.sh docker/scripts/retry-curl.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/setup-apt-mirror.sh /usr/local/bin/install-nodejs.sh /usr/local/bin/retry-curl.sh && \
    /usr/local/bin/setup-apt-mirror.sh "${AXON_APT_MIRROR}"

# Install basic build tools and packaging dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    pkg-config \
    git \
    curl \
    wget \
    ca-certificates \
    lsb-release \
    software-properties-common \
    gnupg \
    debhelper \
    dpkg-dev \
    devscripts \
    fakeroot \
    xxd \
    vim-common \
    && rm -rf /var/lib/apt/lists/*

# Enable focal-backports for debhelper 13
RUN ubuntu_mirror="$(cat /etc/apt/axon-ubuntu-mirror-url)" && \
    add-apt-repository -y "deb ${ubuntu_mirror} focal-backports main universe" && \
    apt-get update && \
    apt-get install -y -t focal-backports debhelper && \
    rm -rf /var/lib/apt/lists/*

# Install common dependencies (Ubuntu 20.04 versions)
RUN apt-get update && apt-get install -y \
    nlohmann-json3-dev \
    libyaml-cpp-dev \
    liblz4-dev \
    libzstd-dev \
    libre2-dev \
    libboost-dev \
    libboost-system-dev \
    libboost-log-dev \
    libboost-thread-dev \
    libboost-filesystem-dev \
    libssl-dev \
    libsqlite3-dev \
    libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

ARG CURL_RETRY_ARGS="--connect-timeout 30 --max-time 600"
ARG CURL_RETRY_ATTEMPTS=5
ARG CURL_RETRY_DELAY=10

# Install Node.js 18 for panel build
RUN CURL_RETRY_ARGS="${CURL_RETRY_ARGS}" CURL_RETRY_ATTEMPTS="${CURL_RETRY_ATTEMPTS}" CURL_RETRY_DELAY="${CURL_RETRY_DELAY}" NODE_MAJOR=18 /usr/local/bin/install-nodejs.sh

# Load host-prefetched MCAP library for FetchContent.
ARG MCAP_COMMIT=a7eeff1383cc95a29dd9c5cac94104d277b5414e
COPY packaging/deb/source-cache/mcap-a7eeff1383cc95a29dd9c5cac94104d277b5414e.tar.gz /tmp/package-sources/mcap.tar.gz
RUN \
    cd /tmp && \
    tar xzf /tmp/package-sources/mcap.tar.gz && \
    mkdir -p /opt/mcap && \
    mv "mcap-${MCAP_COMMIT}"/* /opt/mcap/ && \
    rm -rf "mcap-${MCAP_COMMIT}" && \
    echo "MCAP loaded to /opt/mcap from host cache commit ${MCAP_COMMIT}"

# Load host-prefetched cpp-httplib for axon-panel FetchContent.
COPY packaging/deb/source-cache/cpp-httplib-0.15.3.tar.gz /tmp/package-sources/httplib.tar.gz
RUN \
    cd /tmp && \
    tar xzf /tmp/package-sources/httplib.tar.gz && \
    mkdir -p /opt/cpp-httplib && \
    mv cpp-httplib-0.15.3/* /opt/cpp-httplib/ && \
    rm -rf cpp-httplib-0.15.3 && \
    echo "cpp-httplib loaded to /opt/cpp-httplib v0.15.3"

# Install AWS SDK for C++ (required for axon-transfer for S3 uploads)
# Build from source with minimal components to reduce build time
# Build statically to create portable packages (no runtime dependency on AWS SDK)
# This takes ~15-20 minutes but is required for S3 upload functionality
ARG AWS_SDK_CPP_VERSION=1.11.479
RUN apt-get update && apt-get install -y ninja-build zlib1g-dev && rm -rf /var/lib/apt/lists/*
COPY packaging/deb/source-cache/aws-sdk-cpp-1.11.479.tar.gz /tmp/package-sources/aws-sdk-cpp.tar.gz
RUN \
    cd /tmp && \
    tar xzf /tmp/package-sources/aws-sdk-cpp.tar.gz && \
    cd "aws-sdk-cpp-${AWS_SDK_CPP_VERSION}" && \
    cmake -B build \
        -GNinja \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_ONLY="s3;transfer" \
        -DBUILD_SHARED_LIBS=OFF \
        -DENABLE_TESTING=OFF \
        -DAUTOR_RUN_TESTS=OFF \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DUNITY_BUILD=OFF && \
    cmake --build build -j"$(nproc)" && \
    cmake --install build && \
    rm -rf "/tmp/aws-sdk-cpp-${AWS_SDK_CPP_VERSION}" /tmp/package-sources

# Set working directory
WORKDIR /axon

# Copy packaging scripts
COPY packaging/deb/scripts/ /usr/local/bin/
RUN chmod +x /usr/local/bin/*.sh 2>/dev/null || true

CMD ["/bin/bash"]
