#!/usr/bin/make -f

# See debhelper(7) (uncomment to enable)
#DH_VERBOSE = 1

# See EXAMPLES in dpkg-buildflags(1) and read /usr/share/dpkg/*
DPKG_EXPORT_BUILDFLAGS = 1
include /usr/share/dpkg/buildflags.mk

# Skip tests
DEB_BUILD_OPTIONS += nocheck

# Get the repo root - use AXON_REPO_ROOT from environment if set, otherwise compute
ifeq ($(origin AXON_REPO_ROOT),environment)
REPO_ROOT := $(AXON_REPO_ROOT)
else
REPO_ROOT := $(shell cd $(CURDIR)/../../../.. && pwd)
endif

# Get ROS_DISTRO from environment or default to humble
ROS_DISTRO ?= humble

# main packaging script based on dh7 syntax
%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_INSTALL_PREFIX=/opt/axon \
		-DAXON_REPO_ROOT=$(REPO_ROOT) \
		-DROS_DISTRO=$(ROS_DISTRO) \
		-DCMAKE_PREFIX_PATH=/opt/ros/$(ROS_DISTRO)

override_dh_auto_install:
	dh_auto_install
	# Install plugin to correct location
	mkdir -p debian/$(shell dh_listpackages)/opt/axon/plugins
	mv debian/$(shell dh_listpackages)/opt/axon/lib/libaxon_ros2_plugin.so \
	   debian/$(shell dh_listpackages)/opt/axon/plugins/ || true

override_dh_auto_clean:
	dh_auto_clean || true
	rm -rf obj-* debian/.debhelper debian/debhelper-build-stamp debian/files 2>/dev/null || true
