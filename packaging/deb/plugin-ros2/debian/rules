#!/usr/bin/make -f

# Get ROS_DISTRO from environment or default to humble
ROS_DISTRO ?= humble

%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- -DROS_DISTRO=$(ROS_DISTRO)

override_dh_auto_install:
	dh_auto_install
	# Install plugin to correct location
	mkdir -p debian/axon-plugin-ros2/opt/axon/plugins
	mv debian/axon-plugin-ros2/opt/axon/lib/libaxon_ros2_plugin.so \
	   debian/axon-plugin-ros2/opt/axon/plugins/ || true
