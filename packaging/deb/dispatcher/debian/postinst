#!/bin/sh
# SPDX-FileCopyrightText: 2026 ArcheBase
# SPDX-License-Identifier: MulanPSL-2.0
set -e

# Create symlink in /usr/bin for easy access
if [ ! -e /usr/bin/axon ]; then
    ln -sf /opt/axon/bin/axon /usr/bin/axon
fi

# Install bash completion symlink
if [ -d /usr/share/bash-completion/completions ]; then
    ln -sf /opt/axon/share/bash-completion/completions/axon \
           /usr/share/bash-completion/completions/axon 2>/dev/null || true
fi

# Add to /etc/axon directories for runtime config
if [ ! -d /etc/axon ]; then
    mkdir -p /etc/axon
fi

if [ ! -d /axon ]; then
    mkdir -p /axon
fi

exit 0
