#!/usr/bin/make -f

# See debhelper(7) (uncomment to enable)
#DH_VERBOSE = 1

# See EXAMPLES in dpkg-buildflags(1) and read /usr/share/dpkg/*
DPKG_EXPORT_BUILDFLAGS = 1
include /usr/share/dpkg/buildflags.mk

# Skip tests
DEB_BUILD_OPTIONS += nocheck

# Get the repo root - assume we're building from apps/ subdirectory
REPO_ROOT := $(shell cd $(CURDIR)/../.. && pwd)

# main packaging script based on dh7 syntax
%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_INSTALL_PREFIX=/opt/axon -DAXON_REPO_ROOT=$(REPO_ROOT)

# Skip clean reconfiguration to avoid path issues
override_dh_auto_clean:
	dh_auto_clean || true
	rm -rf obj-* debian/.debhelper debian/debhelper-build-stamp debian/files 2>/dev/null || true
