#!/usr/bin/make -f

# See debhelper(7) (uncomment to enable)
#DH_VERBOSE = 1

# See EXAMPLES in dpkg-buildflags(1) and read /usr/share/dpkg/*
DPKG_EXPORT_BUILDFLAGS = 1
include /usr/share/dpkg/buildflags.mk

# Skip tests
DEB_BUILD_OPTIONS += nocheck

# Get the repo root - use AXON_REPO_ROOT from environment if set, otherwise compute
ifeq ($(origin AXON_REPO_ROOT),environment)
REPO_ROOT := $(AXON_REPO_ROOT)
else
REPO_ROOT := $(shell cd $(CURDIR)/../.. && pwd)
endif

# main packaging script based on dh7 syntax
%:
	dh $@

override_dh_auto_configure:
	# Use pre-downloaded MCAP if available (Ubuntu 24.04+)
	if [ -d "/opt/mcap" ]; then \
		dh_auto_configure -- -DCMAKE_INSTALL_PREFIX=/opt/axon -DAXON_REPO_ROOT=$(REPO_ROOT) -DFETCHCONTENT_SOURCE_DIR_MCAP=/opt/mcap; \
	else \
		dh_auto_configure -- -DCMAKE_INSTALL_PREFIX=/opt/axon -DAXON_REPO_ROOT=$(REPO_ROOT); \
	fi

override_dh_install:
	dh_install
	# Install systemd service template
	install -D -m 644 $(REPO_ROOT)/packaging/deb/systemd/axon-recorder@.service \
		debian/$(shell dh_listpackages)/lib/systemd/system/axon-recorder@.service
	# Install plugin enable helper script
	install -D -m 755 $(REPO_ROOT)/packaging/deb/systemd/axon-recorder-enable \
		debian/$(shell dh_listpackages)/opt/axon/bin/axon-recorder-enable

# Skip clean reconfiguration to avoid path issues
override_dh_auto_clean:
	dh_auto_clean || true
	rm -rf obj-* debian/.debhelper debian/debhelper-build-stamp debian/files 2>/dev/null || true
