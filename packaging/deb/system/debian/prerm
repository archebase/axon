#!/bin/sh
# SPDX-FileCopyrightText: 2026 ArcheBase
# SPDX-License-Identifier: MulanPSL-2.0
set -e

if [ -d /run/systemd/system ]; then
    if systemctl is-active --quiet axon-system.service 2>/dev/null; then
        systemctl stop axon-system.service || true
    fi
    if systemctl is-enabled --quiet axon-system.service 2>/dev/null; then
        systemctl disable axon-system.service || true
    fi
fi

exit 0
