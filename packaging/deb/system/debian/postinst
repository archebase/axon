#!/bin/sh
# SPDX-FileCopyrightText: 2026 ArcheBase
# SPDX-License-Identifier: MulanPSL-2.0
set -e

# Create axon user and group if they don't exist.
if ! getent passwd axon > /dev/null 2>&1; then
    adduser --system --no-create-home --quiet --group axon || true
fi

if [ ! -d /etc/axon ]; then
    mkdir -p /etc/axon
    chmod 755 /etc/axon
fi

if [ ! -d /var/lib/axon/system ]; then
    mkdir -p /var/lib/axon/system
    chown axon:axon /var/lib/axon/system
    chmod 755 /var/lib/axon/system
fi

if [ ! -d /var/log/axon ]; then
    mkdir -p /var/log/axon
    chown axon:axon /var/log/axon
    chmod 755 /var/log/axon
fi

if [ ! -f /etc/axon/system.yaml ] && [ -f /opt/axon/share/config/system.yaml ]; then
    cp /opt/axon/share/config/system.yaml /etc/axon/system.yaml
    chmod 644 /etc/axon/system.yaml
fi

if [ -d /run/systemd/system ]; then
    systemctl daemon-reload || true
fi

exit 0
