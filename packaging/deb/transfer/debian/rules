#!/usr/bin/make -f

# Skip tests
export DEB_BUILD_OPTIONS = nocheck

%:
	dh $@

override_dh_auto_configure:
	# Use pre-downloaded MCAP if available (Ubuntu 24.04+)
	if [ -d "/opt/mcap" ]; then \
		dh_auto_configure -- -DCMAKE_INSTALL_PREFIX=/opt/axon -DAXON_REPO_ROOT=$(AXON_REPO_ROOT) -DFETCHCONTENT_SOURCE_DIR_MCAP=/opt/mcap; \
	else \
		dh_auto_configure -- -DCMAKE_INSTALL_PREFIX=/opt/axon -DAXON_REPO_ROOT=$(AXON_REPO_ROOT); \
	fi

override_dh_auto_clean:
	dh_auto_clean || true
	rm -rf obj-* debian/.debhelper debian/debhelper-build-stamp debian/files 2>/dev/null || true
